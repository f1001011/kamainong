/// SVIP每日奖励记录
model SvipRewardRecord {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  productId   Int       @map("product_id")
  svipLevel   Int       @map("svip_level")
  amount      Decimal   @db.Decimal(15, 2)
  rewardDate  String    @map("reward_date") @db.VarChar(10)
  status      String    @default("SETTLED") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([userId, productId, rewardDate], map: "unique_svip_reward_user_product_date")
  @@index([userId], map: "idx_svip_reward_user_id")
  @@index([rewardDate], map: "idx_svip_reward_date")
  @@map("svip_reward_records")
}

/// 周薪配置表
model WeeklySalary {
  id              Int       @id @default(autoincrement())
  minRecharge     Decimal   @db.Decimal(15, 2) @map("min_recharge")
  rewardAmount    Decimal   @db.Decimal(15, 2) @map("reward_amount")
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  claims          WeeklySalaryClaim[]

  @@map("weekly_salaries")
}

/// 周薪领取记录
model WeeklySalaryClaim {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  weekStart       DateTime  @map("week_start")
  weekEnd         DateTime  @map("week_end")
  teamRecharge    Decimal   @db.Decimal(15, 2) @map("team_recharge")
  salaryId        Int       @map("salary_id")
  amount          Decimal   @db.Decimal(15, 2)
  status          String    @default("CLAIMED") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id])
  salary          WeeklySalary @relation(fields: [salaryId], references: [id])

  @@unique([userId, weekStart], map: "unique_weekly_salary_claim_user_week")
  @@index([userId], map: "idx_weekly_salary_claim_user_id")
  @@map("weekly_salary_claims")
}

