// Prisma Schema for Lendlease - 哥伦比亚市场理财投资平台
// 最后更新：2026-03-12
// 版本：v2.0.0

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ================================
// 用户相关表
// ================================

/**
 * 用户表
 * @description 用户模块核心表，承载用户基本信息、邀请关系、等级体系、余额信息、签到状态等关键数据
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.1节 - 用户模块
 * 
 * 邀请关系说明：
 * - inviterId: 一级上级（直接邀请人）
 * - level2InviterId: 二级上级（邀请人的邀请人），注册时自动填充
 * - level3InviterId: 三级上级（邀请人的邀请人的邀请人），注册时自动填充
 * - 只存储三级上级ID，避免递归查询
 */
model User {
  id              Int       @id @default(autoincrement())
  phone           String    @unique @db.VarChar(20)        // 手机号（10位数字）
  password        String    @db.VarChar(255)               // AES加密存储，后台可解密
  nickname        String?   @db.VarChar(50)                // 用户昵称
  avatar          String?   @db.VarChar(500)               // 用户头像URL
  inviteCode      String    @unique @db.VarChar(8)         // 8位邀请码，排除0OIL1
  
  // === 邀请关系（依据：开发文档.md 第14.2.2节）===
  inviterId       Int?                                      // 一级上级（直接邀请人）
  inviter         User?     @relation("Referral", fields: [inviterId], references: [id])
  invitees        User[]    @relation("Referral")
  
  // 二级、三级上级冗余字段（用于返佣计算，注册时自动填充）
  // 注意：一级上级使用 inviterId，不再冗余 level1InviterId
  level2InviterId Int?                                      // 二级上级（邀请人的邀请人）
  level3InviterId Int?                                      // 三级上级（邀请人的邀请人的邀请人）
  
  // === 等级信息 ===
  vipLevel        Int       @default(0)                     // VIP等级 0-8
  svipLevel       Int       @default(0)                     // SVIP等级 0-8
  
  // === 余额信息（依据：开发文档.md 第4.4节）===
  availableBalance  Decimal @default(0) @db.Decimal(15, 2) // 可用余额
  frozenBalance     Decimal @default(0) @db.Decimal(15, 2) // 冻结余额（提现中）
  
  // === 提现门槛判断（新系统：充值+购买任意付费产品）===
  hasPurchasedPo0   Boolean @default(false)                 // 旧字段保留向后兼容
  hasPurchasedOther Boolean @default(false)                 // 旧字段保留向后兼容
  hasPurchasedPaid  Boolean @default(false)                 // 是否已购买任意付费产品（新系统提现条件）
  
  // === 有效邀请判断 ===
  hasRecharged              Boolean @default(false)         // 是否进行过充值
  hasPurchasedAfterRecharge Boolean @default(false)         // 充值后是否购买过产品
  
  // === 返佣判断（依据：开发文档.md 第4.5节）===
  firstPurchaseDone Boolean @default(false)                 // 是否已完成首次付费产品购买（用于返佣判断）
  
  // === 签到窗口期（依据：开发文档.md 第9节-普通用户签到规则）===
  signInWindowStart     DateTime? @db.Date                  // 签到窗口期开始日期（注册日期，注册时自动填充）
  signInWindowExpired   Boolean @default(false)             // 签到窗口期是否已过期（7天后自动标记）
  signInCurrentStreak   Int @default(0)                     // 当前连续签到天数（0-3，漏签则重置为0）
  signInMaxStreak       Int @default(0)                     // 窗口期内最大连续签到天数（用于判断是否达成3天）
  signInCompleted       Boolean @default(false)             // 是否已完成3天签到任务（有效邀请判断）
  lastSignInDate        DateTime? @db.Date                  // 最后签到日期（用于判断连续性）
  
  // === 状态与登录信息 ===
  status          UserStatus @default(ACTIVE)
  registerIp      String?    @db.VarChar(50)
  lastLoginIp     String?    @db.VarChar(50)
  lastLoginAt     DateTime?
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  // === 关联关系 ===
  bankCards       BankCard[]
  rechargeOrders  RechargeOrder[]
  withdrawOrders  WithdrawOrder[]
  positionOrders  PositionOrder[]
  incomeRecords   IncomeRecord[]                            // 收益发放记录（依据：02.1-数据库设计.md 第2.3节）
  transactions    Transaction[]
  notifications   Notification[]
  loginLogs       UserLoginLog[]
  userPurchases   UserProductPurchase[]                     // 用户产品购买记录（限购控制）
  
  // 返佣记录关联
  commissionsReceived    CommissionRecord[] @relation("CommissionReceiver")
  commissionsContributed CommissionRecord[] @relation("CommissionSource")
  
  // 活动相关关联（依据：02.1-数据库设计.md 第2.6节）
  signInRecords   SignInRecord[]                            // 签到记录
  activityRewards ActivityReward[]                          // 活动奖励领取记录
  
  // 有效邀请关联（依据：02.1-数据库设计.md 第2.6节）
  validInvitationsAsInviter ValidInvitation[] @relation("ValidInvitationInviter")  // 作为邀请人
  validInvitationsAsInvitee ValidInvitation[] @relation("ValidInvitationInvitee")  // 作为被邀请人
  
  // 公告已读记录关联
  announcementReads AnnouncementRead[]
  
  // 用户在线状态关联
  onlineStatus    UserOnlineStatus?
  
  // 渠道链接关联
  marketingChannel  MarketingChannel?
  
  // === 新功能关联（Lendlease重构）===
  communityPosts       CommunityPost[]
  communityComments    CommunityComment[]
  communityLikes       CommunityLike[]
  spinRecords          SpinRecord[]
  spinChances          SpinChance[]
  weeklySalaryClaims   WeeklySalaryClaim[]
  prizePoolClaims      PrizePoolClaim[]
  svipRewardRecords    SvipRewardRecord[]
  giftCodeClaims       GiftCodeClaim[]
  
  @@index([phone], map: "idx_user_phone")
  @@index([inviteCode], map: "idx_user_invite_code")
  @@index([inviterId], map: "idx_user_inviter_id")
  @@index([level2InviterId], map: "idx_user_level2_inviter_id")
  @@index([level3InviterId], map: "idx_user_level3_inviter_id")
  @@index([signInWindowStart], map: "idx_user_signin_window_start")  // 用于签到窗口期过期定时任务
}

/**
 * 用户状态枚举
 * @description 用户账号状态
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.1节
 */
enum UserStatus {
  ACTIVE   // 正常
  BANNED   // 封禁
}

/**
 * 银行卡表
 * @description 用户银行卡管理，支持提现功能。敏感字段使用 AES 加密存储
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.1节 - BankCard表
 * 
 * 安全说明：
 * - accountNo: AES加密存储，后台可解密显示
 * - documentNo: AES加密存储，后台可解密显示
 * - accountNoMask: 脱敏显示，供前端使用
 * 
 * 软删除说明：
 * - 删除银行卡时设置 isDeleted=true, deletedAt=当前时间
 * - 历史提现记录中保留银行卡快照信息用于审计追溯
 */
model BankCard {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  
  // === 银行信息 ===
  bankCode        String        @db.VarChar(20)               // 银行编码（对应支付通道）
  bankName        String        @db.VarChar(100)              // 银行名称（快照）
  
  // === 账户信息（敏感字段 AES 加密）===
  accountNo       String        @db.VarChar(255)              // AES加密存储，后台可解密显示
  accountNoMask   String        @db.VarChar(50)               // 脱敏显示 ****1234（前端使用）
  accountName     String        @db.VarChar(100)              // 收款人姓名
  phone           String        @db.VarChar(20)               // 收款人手机号
  
  // === 证件信息（摩洛哥961通道不需要，保留兼容其他通道） ===
  documentType    DocumentType?                               // 证件类型（可选）
  documentNo      String?       @db.VarChar(255)              // AES加密存储（可选）
  
  // === 软删除字段（依据：开发文档.md 第16.7节）===
  isDeleted       Boolean       @default(false)               // 是否已删除
  deletedAt       DateTime?                                   // 删除时间
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // === 关联关系 ===
  withdrawOrders  WithdrawOrder[]
  
  // 银行关联（用于验证银行是否启用）
  bank            Bank?         @relation(fields: [bankCode], references: [code])
  
  @@index([userId], map: "idx_bank_card_user_id")
  @@index([accountNoMask], map: "idx_bank_card_account_no_mask")  // 脱敏字段可用于模糊查询
  @@index([bankCode], map: "idx_bank_card_bank_code")
  @@map("bank_cards")
}

/**
 * 证件类型枚举
 * @description 银行卡绑定时的证件类型（摩洛哥）
 */
enum DocumentType {
  CC    // بطاقة الهوية الوطنية（国民身份证，最常用）
  CE    // بطاقة الإقامة（居留证）
  NIT   // الرقم الضريبي（税号）
  PP    // جواز السفر（护照）
}

// ================================
// 产品相关表
// ================================

/**
 * 产品表
 * @description 理财产品核心表，包含产品基本信息、收益配置、等级配置、限购配置等
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.2节 - 产品模块
 * 
 * ⚠️ 重要：业务逻辑判断规则（依据：开发文档.md 第8.0.0节）
 * - 判断是否体验产品：使用 type === 'TRIAL'，禁止使用 code === 'Po0'
 * - 判断是否付费产品：使用 type === 'PAID'，禁止使用 code !== 'Po0'
 * - 判断产品系列：使用 series === 'PO' 或 series === 'VIP'
 * - code 字段仅用于后台展示和管理，禁止在业务逻辑中使用
 * 
 * 产品标识使用场景：
 * | 场景           | 使用字段    | 说明                           |
 * |---------------|------------|-------------------------------|
 * | 数据库关联     | id         | 持仓订单、购买记录等表使用 productId 外键 |
 * | 前端API请求    | id         | 购买产品、查询详情等 API 使用 ID       |
 * | 返佣/首购判断  | type       | 判断是否触发返佣                    |
 * | 等级要求判断   | series     | 判断产品系列                       |
 * | 前端列表显示   | name       | 产品卡片、订单详情显示名称             |
 */
model Product {
  id              Int           @id @default(autoincrement())
  code            String        @unique @db.VarChar(20)     // 编码（后台可改，禁止用于逻辑判断）
  name            String        @db.VarChar(100)            // 产品名称
  
  // === 产品分类（用于业务逻辑判断）===
  type            ProductType                               // TRIAL=体验 PAID=付费
  series          ProductSeries                             // PO=Po系列 VIP=VIP系列
  
  // === 收益配置 ===
  price           Decimal       @db.Decimal(15, 2)          // 产品价格
  dailyIncome     Decimal       @db.Decimal(15, 2)          // 每日收益
  cycleDays       Int                                       // 周期天数
  totalIncome     Decimal       @db.Decimal(15, 2)          // 总收益 = dailyIncome × cycleDays
  
  // === 等级配置 ===
  grantVipLevel   Int           @default(0)                 // 赠送VIP等级（购买后获得）
  grantSvipLevel  Int           @default(0)                 // 赠送SVIP等级（购买后获得）
  requireVipLevel Int           @default(0)                 // 购买所需VIP等级
  
  // === 限购配置 ===
  purchaseLimit   Int           @default(1)                 // 限购数量（终身，向后兼容保留）
  
  // === 全局库存配置（新增） ===
  globalStock       Int?                                      // 全局库存（null=无限）
  globalSold        Int           @default(0)                 // 全局已售
  userPurchaseLimit Int?                                      // 单用户限购（null=无限）
  displayUserLimit  Int?                                      // 前端显示的单用户限购数
  
  // === SVIP配置（新增） ===
  svipDailyReward   Decimal?      @db.Decimal(15, 2)          // SVIP每日奖励金额
  svipRequireCount  Int?                                      // 达成SVIP需要的持仓数
  
  // === 理财产品配置（新增） ===
  returnPrincipal   Boolean       @default(false)             // 到期是否返还本金
  productStatus     String        @default("OPEN") @db.VarChar(20) // OPEN/COMING_SOON/CLOSED
  
  // === 展示配置 ===
  mainImage       String?       @db.VarChar(500)            // 产品主图
  detailImages    Json?                                     // 产品详情图列表（JSON数组）
  detailContent   String?       @db.Text                    // 富文本详情内容
  
  // === 角标配置 ===
  showRecommendBadge Boolean    @default(false)             // 是否显示新手推荐角标
  customBadgeText    String?    @db.VarChar(50)             // 自定义角标文案
  
  // === 状态与排序 ===
  status          ProductStatus @default(ACTIVE)            // 产品状态
  sortOrder       Int           @default(0)                 // 排序（数值越大越靠前）
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // === 关联关系 ===
  positionOrders  PositionOrder[]                           // 持仓订单
  userPurchases   UserProductPurchase[]                     // 用户购买记录
  svipRewardRecords SvipRewardRecord[]                     // SVIP奖励记录
  
  @@index([type, series], map: "idx_product_type_series")
  @@index([status, sortOrder], map: "idx_product_status_sort_order")
  @@map("products")
}

/**
 * 产品类型枚举
 * @description 用于判断产品是体验产品还是付费产品，决定是否触发返佣
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.2节
 * 
 * 业务规则：
 * - TRIAL（体验产品）：不触发上级返佣
 * - PAID（付费产品）：触发上级返佣（首次购买时）
 */
enum ProductType {
  TRIAL      // 体验产品（不触发返佣）
  PAID       // 付费产品（触发返佣）
  FINANCIAL  // 理财产品（到期返本+利息）
}

/**
 * 产品系列枚举
 * @description 用于区分产品系列，PO系列无等级要求，VIP系列需对应VIP等级
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.2节
 */
enum ProductSeries {
  PO          // 保留（向后兼容）
  VIP         // 保留（向后兼容）
  VIC         // VIC系列（VIC1-VIC5）
  NWS         // NWS系列（NWS6-NWS9）
  QLD         // QLD系列（QLD10-QLD12）
  FINANCIAL   // 理财产品系列
}

/**
 * 产品状态枚举
 * @description 产品上下架状态
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.2节
 */
enum ProductStatus {
  ACTIVE    // 上架（用户可见可购买）
  INACTIVE  // 下架（用户不可见）
  DELETED   // 已删除（软删除，历史数据保留）
}

/**
 * 用户产品购买记录表（限购控制）
 * @description 记录用户对每个产品的购买次数，用于限购控制
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.2节 - UserProductPurchase表
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第14.2.1节 - 唯一索引防重复
 * 
 * 并发控制说明：
 * - 唯一索引 [userId, productId] 防止并发重复购买
 * - 购买时先查询记录，如不存在则创建，如存在则检查 purchaseCount < purchaseLimit
 * - 使用事务确保原子性
 * 
 * 业务规则（依据：开发文档.md 第16.8节、第16.9节）：
 * - 赠送产品占用限购名额
 * - 后台可恢复单个产品的购买资格（每次恢复1次购买机会）
 */
model UserProductPurchase {
  id              Int       @id @default(autoincrement())
  userId          Int                                       // 用户ID
  user            User      @relation(fields: [userId], references: [id])
  productId       Int                                       // 产品ID
  product         Product   @relation(fields: [productId], references: [id])
  purchaseCount   Int       @default(1)                     // 已购买次数（包含赠送）
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // 唯一索引：防止并发重复购买（依据：开发文档.md 第14.2.1节）
  @@unique([userId, productId], map: "unique_user_product_purchase")
  @@index([userId], map: "idx_user_product_purchase_user_id")
  @@map("user_product_purchases")
}

// ================================
// 订单相关表
// ================================

/**
 * 充值订单表
 * @file 充值订单模块数据库 Schema
 * @description 用户充值订单管理，对接第三方支付通道，处理异步回调、超时取消、金额差异等场景
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.3节 - RechargeOrder表
 * @depends 开发文档/开发文档.md 第5节 - 充值系统
 * 
 * 核心业务规则：
 * 1. 订单号格式：RC + 日期8位 + 随机10位 = 20位
 * 2. 金额使用 DECIMAL(15,2) 存储，向下取整到分
 * 3. 按回调实际金额充值（actualAmount 可能与 amount 不同）
 * 4. 保存支付链接和第三方订单号，便于对账排查
 * 5. 保存回调原始数据用于问题排查和审计
 * 6. expireAt 索引用于超时任务扫描
 * 
 * 充值金额处理规则（依据：开发文档.md 第5.3节）：
 * - 用户拉单100，实付10 → 按回调金额10充值
 * - 用户拉单100，实付150 → 按回调金额150充值
 * 
 * 超时与延迟回调处理（依据：开发文档.md 第16.1节）：
 * - 订单已超时取消，但后续收到成功回调 → 仍然给用户充值到账，订单状态改为已支付
 * - 回调处理时，无论订单当前状态如何，只要回调验签成功且为支付成功，均按回调金额充值
 */
model RechargeOrder {
  id              Int                 @id @default(autoincrement())
  
  // === 订单基本信息 ===
  orderNo         String              @unique @db.VarChar(20)   // 订单号：RC + 日期8位 + 随机10位
  
  // === 用户关联 ===
  userId          Int                                           // 用户ID
  user            User                @relation(fields: [userId], references: [id])
  
  // === 支付通道关联 ===
  channelId       Int                                           // 支付通道ID
  channel         PaymentChannel      @relation(fields: [channelId], references: [id])
  
  // === 金额信息（依据：开发文档.md 第5.3节）===
  amount          Decimal             @db.Decimal(15, 2)        // 申请金额（用户提交的充值金额）
  actualAmount    Decimal?            @db.Decimal(15, 2)        // 实际支付金额（回调返回，可能与申请金额不同）
  
  // === 第三方支付信息 ===
  thirdOrderNo    String?             @db.VarChar(100)          // 第三方订单号（支付平台返回）
  payUrl          String?             @db.Text                  // 支付链接（跳转支付收银台）
  
  // === 订单状态 ===
  status          RechargeStatus      @default(PENDING_PAYMENT)
  
  // === 风控信息 ===
  createIp        String?             @db.VarChar(50)           // 创建订单时的IP（用于风控分析）
  
  // === 回调信息（依据：开发文档.md 第16.1节）===
  callbackData    Json?                                         // 回调原始数据（完整保存用于排查问题）
  callbackAt      DateTime?                                     // 回调时间
  
  // === 时间信息 ===
  expireAt        DateTime?                                     // 超时时间（从 GlobalConfig.recharge_timeout_minutes 计算，禁止硬编码）
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // === 索引（依据：开发文档.md 第14.0.5节 + 00.3-开发规范.md 第VI节）===
  @@index([userId], map: "idx_recharge_order_user_id")           // 用户订单查询
  @@index([orderNo], map: "idx_recharge_order_order_no")         // 订单号查询
  @@index([status], map: "idx_recharge_order_status")            // 状态筛选
  @@index([expireAt], map: "idx_recharge_order_expire_at")       // 超时任务扫描（定时任务必须）
  @@map("recharge_orders")
}

/**
 * 充值订单状态枚举
 * @description 充值订单的生命周期状态
 * @depends 开发文档/开发文档.md 第5.5节 - 充值订单状态
 * 
 * 状态流转：
 * PENDING_PAYMENT → PAID（支付成功回调）
 * PENDING_PAYMENT → CANCELLED（用户取消或超时取消）
 * PENDING_PAYMENT → FAILED（支付失败回调）
 * CANCELLED → PAID（已取消但收到延迟成功回调时，仍充值到账）
 */
enum RechargeStatus {
  PENDING_PAYMENT  // 待支付（已生成订单，等待用户付款）
  PAID             // 已支付（收到成功回调，已到账）
  FAILED           // 失败（支付失败）
  CANCELLED        // 已取消（用户主动取消或超时自动取消）
}

/**
 * 提现订单表
 * @file 提现订单模块数据库 Schema
 * @description 用户提现订单，包含审核流程、手续费计算、银行卡快照保存，支持免审核自动通过功能
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.3节 - WithdrawOrder表
 * @depends 开发文档/开发文档.md 第7节 - 提现系统相关业务规则
 * 
 * 核心业务规则：
 * 1. 订单号格式：WD + 日期8位 + 随机10位 = 20位
 * 2. 金额使用 DECIMAL(15,2) 存储，向下取整到分
 * 3. actualAmount = amount - fee（实际到账金额）
 * 4. 手续费率从 GlobalConfig.withdraw_fee_percent 读取（禁止硬编码）
 * 
 * 银行卡快照机制说明（依据：开发文档.md 第16.7节）：
 * - 快照写入时机：用户申请提现时，将当前选择的银行卡完整信息写入 bankCardSnapshot
 * - 快照内容：银行名称、银行编码、账号（完整）、持卡人姓名、手机号、证件类型、证件号、账户类型
 * - 不可变性：快照数据一旦写入不可修改，即使用户后续修改或删除原银行卡
 * - 用途：银行卡删除后仍能显示原信息、审计追溯、财务对账
 * 
 * 快照数据结构示例：
 * {
 *   "bankCode": "COP001",
 *   "bankName": "Bancolombia",
 *   "accountNo": "1234567890123456",
 *   "accountNoMask": "****3456",
 *   "accountName": "Juan Perez",
 *   "phone": "987654321",
 *   "documentType": "CC",
 *   "documentNo": "12345678",
 *   "documentNo": "AB123456",
 *   "snapshotAt": "2026-02-03T10:30:00.000Z"
 * }
 * 
 * 免审核规则（依据：开发文档.md 第13.9.4节）：
 * - auto_approve_enabled: 免审核开关
 * - auto_approve_threshold: 免审核金额阈值
 * - auto_approve_daily_limit: 每用户每日最多免审核次数
 * - auto_approve_time_range: 免审核时间窗口
 * - auto_approve_new_user_days: 新用户冷却期（天）
 */
model WithdrawOrder {
  id              Int               @id @default(autoincrement())
  
  // === 订单基本信息 ===
  orderNo         String            @unique @db.VarChar(20)       // 订单号：WD + 日期8位 + 随机10位
  
  // === 用户关联 ===
  userId          Int                                             // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 银行卡信息（依据：开发文档.md 第16.7节）===
  bankCardId      Int                                             // 银行卡ID
  bankCard        BankCard          @relation(fields: [bankCardId], references: [id])
  bankCardSnapshot Json?                                          // 提现时银行卡完整信息快照（用于审计追溯）
  
  // === 支付通道信息 ===
  channelId       Int?                                            // 支付通道ID（审核通过后分配）
  channel         PaymentChannel?   @relation(fields: [channelId], references: [id])
  channelOrderNo  String?           @db.VarChar(20)               // 发给支付通道的订单号（默认=orderNo，重试时重新生成，用于回调查找）
  thirdOrderNo    String?           @db.VarChar(100)              // 第三方订单号（支付平台返回）
  
  // === 金额信息（依据：开发文档.md 第7节）===
  amount          Decimal           @db.Decimal(15, 2)            // 申请提现金额
  fee             Decimal           @db.Decimal(15, 2)            // 手续费 = amount × withdraw_fee_percent%
  actualAmount    Decimal           @db.Decimal(15, 2)            // 实际到账金额 = amount - fee
  
  // === 订单状态 ===
  status          WithdrawStatus    @default(PENDING_REVIEW)      // 订单状态
  
  // === 免审核配置（依据：开发文档.md 第13.9.4节）===
  isAutoApproved    Boolean         @default(false)               // 是否免审核自动通过
  autoApproveReason String?         @db.VarChar(200)              // 免审核原因说明（如：金额100以下自动通过）
  
  // === 审核信息 ===
  reviewedBy      Int?                                            // 审核人ID（管理员ID）
  reviewedAt      DateTime?                                       // 审核时间
  reviewRemark    String?           @db.VarChar(500)              // 审核备注（内部使用）
  rejectReason    String?           @db.VarChar(500)              // 拒绝原因（展示给用户）
  
  // === 打款信息 ===
  paidAt          DateTime?                                       // 打款完成时间
  callbackData    Json?                                           // 回调原始数据（完整保存用于排查问题）
  callbackAt      DateTime?                                       // 回调时间
  
  // === 代付重试信息 ===
  retryCount        Int             @default(0)                   // 代付重试次数
  payoutFailReason  String?         @db.VarChar(500)              // 最近一次代付失败原因（区别于 rejectReason 审核拒绝原因）
  payoutAttempts    Json?                                         // 代付尝试历史记录（JSON数组，包含每次尝试的通道、结果、时间等）
  
  // === 风控信息 ===
  createIp        String?           @db.VarChar(50)               // 创建订单时的IP（用于风控分析）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引（依据：开发文档.md 第14.0.5节 + 00.3-开发规范.md 第VI节）===
  @@index([userId], map: "idx_withdraw_order_user_id")            // 用户订单查询
  @@index([orderNo], map: "idx_withdraw_order_order_no")          // 订单号查询
  @@index([status], map: "idx_withdraw_order_status")             // 审核列表筛选
  @@index([createdAt], map: "idx_withdraw_order_created_at")      // 时间范围查询
  @@index([isAutoApproved], map: "idx_withdraw_order_auto_approved") // 免审核统计
  @@index([channelOrderNo], map: "idx_withdraw_order_channel_order_no") // 回调查找（代付重试时使用 channelOrderNo）
  @@map("withdraw_orders")
}

/**
 * 提现订单状态枚举
 * @description 提现订单的生命周期状态
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.3节 - WithdrawStatus枚举
 * @depends 开发文档/开发文档.md 第7节 - 提现订单状态
 * 
 * 状态流转：
 * PENDING_REVIEW → APPROVED（审核通过/免审核自动通过，同时提交代付）
 * PENDING_REVIEW → REJECTED（审核拒绝，已退回余额）
 * APPROVED → COMPLETED（代付成功回调）
 * APPROVED → PAYOUT_FAILED（代付失败回调，余额仍冻结，待管理员处理）
 * PAYOUT_FAILED → APPROVED（管理员选择新通道重试代付）
 * PAYOUT_FAILED → FAILED（管理员驳回退款，退回余额）
 * 
 * 余额处理规则（依据：开发文档.md 第7节）：
 * - 申请提现时：从可用余额扣减到冻结余额
 * - 审核拒绝时：从冻结余额退回到可用余额
 * - 代付失败(PAYOUT_FAILED)时：余额保持冻结，不退回（等待管理员决策）
 * - 管理员驳回(FAILED)时：从冻结余额退回到可用余额
 * - 打款成功时：从冻结余额扣减
 */
enum WithdrawStatus {
  PENDING_REVIEW  // 待审核（新申请的订单）
  APPROVED        // 已通过（已提交代付）
  PAYOUT_FAILED   // 代付失败（余额仍冻结，待管理员处理：可驳回退款或选择新通道重试）
  COMPLETED       // 已完成（代付成功）
  FAILED          // 失败（管理员驳回代付失败订单，已退回余额）
  REJECTED        // 已拒绝（审核拒绝，已退回余额）
}

/**
 * 持仓订单表
 * @file 持仓订单模块数据库 Schema
 * @description 记录用户购买的产品，跟踪收益发放进度。收益按购买时间+24小时准时发放，最后一笔收益发放时同步完结订单
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.3节 - PositionOrder表
 * @depends 开发文档/开发文档.md 第8.4-8.6节 - 收益发放规则
 * 
 * 核心业务规则：
 * 1. 订单号格式：PO + 日期8位 + 随机10位 = 20位
 * 2. 金额使用 DECIMAL(15,2) 存储，向下取整到分
 * 3. totalIncome = dailyIncome × cycleDays（购买时快照）
 * 4. earnedIncome：累计已发放收益（每次发放后更新）
 * 5. paidDays：已发放天数（每次发放后+1）
 * 
 * 收益发放时机（依据：开发文档.md 第8.4节）：
 * - 计划发放时间 = 购买时间 + 24小时 × 发放序号
 * - 示例：23:51购买 → 第1次：次日23:51 → 第2次：后天23:51
 * - nextSettleAt 存储下次发放时间，定时任务扫描此字段
 * 
 * 订单完结机制（依据：开发文档.md 第8.6节）：
 * - 最后一笔收益发放时同步完结订单（同一事务）
 * - 不使用独立定时任务
 * - 完结时设置 status=COMPLETED, endAt=当前时间
 * 
 * 赠送产品规则（依据：开发文档.md 第16.9节）：
 * - isGift=true 标记为赠送产品
 * - 赠送产品同样24小时后开始发放收益
 * - 赠送产品不触发返佣（因无实际付款）
 * - 赠送产品计入提现门槛、占用限购名额、赠送VIP等级
 */
model PositionOrder {
  id              Int               @id @default(autoincrement())
  
  // === 订单基本信息 ===
  orderNo         String            @unique @db.VarChar(20)       // 订单号：PO + 日期8位 + 随机10位
  
  // === 用户关联 ===
  userId          Int                                             // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 产品关联 ===
  productId       Int                                             // 产品ID
  product         Product           @relation(fields: [productId], references: [id])
  
  // === 金额与收益配置（购买时快照）===
  purchaseAmount  Decimal           @db.Decimal(15, 2)            // 购买金额
  dailyIncome     Decimal           @db.Decimal(15, 2)            // 每日收益
  cycleDays       Int                                             // 周期天数
  totalIncome     Decimal           @db.Decimal(15, 2)            // 总收益 = dailyIncome × cycleDays
  
  // === 收益发放进度 ===
  paidDays        Int               @default(0)                   // 已发放天数（0 ~ cycleDays）
  earnedIncome    Decimal           @default(0) @db.Decimal(15, 2) // 已获收益累计
  
  // === 下次发放时间（用于定时任务扫描）===
  nextSettleAt    DateTime?                                       // 下次收益发放时间（完结后为null）
  
  // === 赠送产品标记 ===
  isGift          Boolean           @default(false)               // 是否为赠送产品
  giftedBy        Int?                                            // 赠送人（管理员ID）
  
  // === 理财产品本金返还标记（新增） ===
  principalReturned Boolean         @default(false)               // 本金是否已返还（理财产品用）
  
  // === 订单状态 ===
  status          PositionStatus    @default(ACTIVE)              // 订单状态
  
  // === 终止信息（管理员终止持仓订单）===
  terminatedBy    Int?                                            // 终止操作人（管理员ID）
  terminatedAt    DateTime?                                       // 终止时间
  terminateReason String?           @db.VarChar(500)              // 终止原因
  
  // === 时间信息 ===
  startAt         DateTime          @default(now())               // 开始时间（购买/赠送时间）
  endAt           DateTime?                                       // 完结时间（最后一笔收益发放时设置）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 关联关系 ===
  incomeRecords     IncomeRecord[]                                // 收益发放记录
  commissionRecords CommissionRecord[]                            // 返佣记录（该订单触发的返佣）
  
  // === 索引（依据：开发文档.md 第14.0.5节 + 00.3-开发规范.md 第VI节）===
  @@index([userId], map: "idx_position_order_user_id")            // 用户持仓查询
  @@index([orderNo], map: "idx_position_order_order_no")          // 订单号查询
  @@index([status], map: "idx_position_order_status")             // 状态筛选
  @@index([nextSettleAt], map: "idx_position_order_next_settle_at") // 收益发放定时任务扫描（关键索引）
  @@map("position_orders")
}

/**
 * 持仓订单状态枚举
 * @description 持仓订单的生命周期状态
 * @depends 开发文档/开发文档.md 第8节 - 持仓订单状态
 * 
 * 状态流转：
 * ACTIVE → COMPLETED（最后一笔收益发放时同步完结）
 * 
 * 注意：
 * - 不支持取消/退款，一旦购买不可撤销
 * - 用户封禁时：收益暂停发放，解封后从暂停位置继续
 */
enum PositionStatus {
  ACTIVE      // 进行中（收益发放中）
  COMPLETED   // 已完成（所有收益已发放）
  TERMINATED  // 已终止（管理员手动终止，停止收益发放）
}

/**
 * 收益发放记录表
 * @file 收益发放记录模块数据库 Schema
 * @description 跟踪每日收益发放，使用 settleSequence（发放序号）而非日期作为唯一约束
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.3节 - IncomeRecord表
 * @depends 开发文档/开发文档.md 第8.5-8.6节 - 收益发放异常处理
 * 
 * 核心设计原则：
 * 1. 使用 settleSequence（发放序号，1~365）而非日期作为唯一约束
 * 2. 唯一索引 [positionId, settleSequence] 防止重复发放
 * 3. 收益按购买时间+24小时发放，可能跨日期，使用序号更准确
 * 4. scheduleAt 索引用于定时任务扫描待发放记录
 * 
 * 发放时间计算（依据：开发文档.md 第8.4节）：
 * - scheduleAt = 购买时间 + 24小时 × settleSequence
 * - settleSequence=1 表示第1次发放，最大值为产品周期天数
 * 
 * 重试机制（依据：开发文档.md 第8.5节）：
 * - 最大重试次数从 GlobalConfig.income_max_retry_count 读取（默认3次）
 * - 超过重试次数后状态变为 FAILED
 * - 失败记录需人工处理（后台异常列表）
 * 
 * 订单完结机制（依据：开发文档.md 第8.6节）：
 * - 最后一笔收益（settleSequence = cycleDays）发放时同步完结订单
 * - 同一事务内完成：收益到账 + 更新持仓状态 + 记录流水
 */
model IncomeRecord {
  id              Int               @id @default(autoincrement())
  
  // === 持仓订单关联 ===
  positionId      Int                                             // 持仓订单ID
  position        PositionOrder     @relation(fields: [positionId], references: [id])
  
  // === 用户关联（依据：02.1-数据库设计.md 第2.3节 IncomeRecord表）===
  userId          Int                                             // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 发放序号与时间 ===
  settleSequence  Int                                             // 发放序号（1表示第1次发放，最大为产品周期天数）
  scheduleAt      DateTime                                        // 计划发放时间（购买时间 + 24小时 × 序号）
  
  // === 金额信息 ===
  amount          Decimal           @db.Decimal(15, 2)            // 收益金额
  
  // === 发放状态 ===
  status          IncomeStatus      @default(PENDING)             // 发放状态
  
  // === 重试机制（依据：开发文档.md 第8.5节）===
  retryCount      Int               @default(0)                   // 重试次数（最大次数从 GlobalConfig.income_max_retry_count 读取）
  lastError       String?           @db.VarChar(500)              // 最近一次失败的错误信息
  
  // === 异常处理（用于后台管理，依据：开发文档.md 第13.13.1节）===
  isHandled       Boolean           @default(false)               // 是否已处理（针对失败记录）
  handledBy       Int?                                            // 处理人（管理员ID）
  handledAt       DateTime?                                       // 处理时间
  handledRemark   String?           @db.VarChar(500)              // 处理备注
  
  // === 实际发放时间 ===
  settledAt       DateTime?                                       // 实际发放时间（成功发放时设置）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 唯一约束（防重复发放，关键约束）===
  @@unique([positionId, settleSequence], map: "unique_income_record_position_sequence")
  
  // === 索引（依据：开发文档.md 第14.0.5节 + 00.3-开发规范.md 第VI节）===
  @@index([positionId], map: "idx_income_record_position_id")     // 持仓订单收益查询
  @@index([userId], map: "idx_income_record_user_id")             // 用户收益查询
  @@index([status], map: "idx_income_record_status")              // 发放状态筛选
  @@index([scheduleAt], map: "idx_income_record_schedule_at")     // 定时任务扫描待发放记录（关键索引）
  @@index([isHandled], map: "idx_income_record_is_handled")       // 异常列表筛选
  @@map("income_records")
}

/**
 * 收益发放状态枚举
 * @description 收益发放记录的生命周期状态
 * @depends 开发文档/开发文档.md 第8.5节 - 收益发放状态
 * 
 * 状态流转：
 * PENDING → SETTLED（发放成功）
 * PENDING → PENDING（发放失败但未超过重试次数，retryCount+1）
 * PENDING → FAILED（超过最大重试次数）
 * FAILED → SETTLED（人工处理后重新发放成功）
 */
enum IncomeStatus {
  PENDING   // 待发放（等待定时任务处理）
  SETTLED   // 已发放（收益已到账用户余额）
  FAILED    // 发放失败（超过重试次数，需人工处理）
  CANCELLED // 已取消（持仓订单被终止时批量取消未发放记录）
}

/**
 * 资金流水表
 * @file 资金流水模块数据库 Schema
 * @description 记录用户每一笔资金变动，金额带正负号表示收入/支出，必须记录变动后余额
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.5节 - Transaction表
 * @depends 开发文档/开发文档.md 第10节 - 资金明细
 * 
 * 核心设计原则：
 * 1. amount 带正负号：正数为收入（充值、收益、返佣等），负数为支出（提现、购买等）
 * 2. balanceAfter 必须记录变动后的可用余额，便于对账和追溯
 * 3. relatedOrderNo 关联订单号，便于追溯资金来源
 * 4. 复合索引 [userId, createdAt] 优化用户流水分页查询
 * 
 * 金额示例：
 * - 充值 100 元：amount = +100.00
 * - 购买产品 50 元：amount = -50.00
 * - 收益 5 元：amount = +5.00
 * - 提现 80 元（冻结）：amount = -80.00
 * - 提现退回 80 元：amount = +80.00
 */
model Transaction {
  id              Int               @id @default(autoincrement())
  userId          Int
  user            User              @relation(fields: [userId], references: [id])
  
  // === 流水类型 ===
  type            TransactionType   // 流水类型
  
  // === 金额信息（依据：开发文档.md 第10节）===
  amount          Decimal           @db.Decimal(15, 2)            // 金额（正为收入，负为支出）
  balanceAfter    Decimal           @db.Decimal(15, 2)            // 变动后余额（必填，用于对账）
  
  // === 关联信息 ===
  relatedOrderNo  String?           @db.VarChar(50)               // 关联订单号（充值/提现/持仓订单号）
  remark          String?           @db.VarChar(500)              // 备注说明
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引（依据：开发文档.md 第14.0.5节 + 00.3-开发规范.md 第VI节）===
  @@index([userId], map: "idx_transaction_user_id")                // 用户流水查询
  @@index([type], map: "idx_transaction_type")                     // 类型筛选
  @@index([createdAt], map: "idx_transaction_created_at")          // 时间范围查询
  @@index([userId, createdAt], map: "idx_transaction_user_id_created_at") // 优化用户流水分页查询（关键复合索引）
  @@map("transactions")
}

/**
 * 流水类型枚举
 * @description 资金流水的类型分类，必须按文档定义，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.5节 - TransactionType枚举
 * 
 * 类型说明（金额正负）：
 * - RECHARGE (+)：充值到账
 * - WITHDRAW_FREEZE (-)：提现冻结（从可用余额扣减）
 * - WITHDRAW_SUCCESS (-)：提现成功（从冻结余额扣减，amount 记录负数用于统计）
 * - WITHDRAW_REFUND (+)：提现退回（退回到可用余额）
 * - PURCHASE (-)：购买产品
 * - INCOME (+)：产品收益到账
 * - REFERRAL_COMMISSION (+)：推荐返佣到账
 * - SIGN_IN (+)：签到奖励到账
 * - ACTIVITY_REWARD (+)：活动奖励到账
 * - REGISTER_BONUS (+)：注册奖励到账
 * - ADMIN_ADD (+)：后台增加余额
 * - ADMIN_DEDUCT (-)：后台扣减余额
 */
enum TransactionType {
  RECHARGE              // 充值
  WITHDRAW_FREEZE       // 提现冻结
  WITHDRAW_SUCCESS      // 提现成功
  WITHDRAW_REFUND       // 提现退回
  PURCHASE              // 购买产品
  INCOME                // 收益到账
  REFERRAL_COMMISSION   // 推荐返佣
  SIGN_IN               // 签到奖励
  ACTIVITY_REWARD       // 活动奖励
  REGISTER_BONUS        // 注册奖励
  ADMIN_ADD             // 后台增加
  ADMIN_DEDUCT          // 后台扣减
  SVIP_DAILY_REWARD     // SVIP每日奖励
  WEEKLY_SALARY         // 周薪奖励
  PRIZE_POOL            // 奖池奖励
  SPIN_WHEEL            // 转盘奖励
  FINANCIAL_PRINCIPAL   // 理财产品本金返还
  COMMUNITY_REWARD      // 社区凭证奖励
  GIFT_CODE             // 礼品码兑换
}

/**
 * 返佣记录表（CommissionRecord）
 * @file 返佣记录模块数据库 Schema
 * @description 记录三级分销的返佣明细，关联触发返佣的持仓订单
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.5节 - CommissionRecord表
 * @depends 开发文档/开发文档.md 第4.5节 - 团队返佣
 * 
 * 三级返佣规则（依据：开发文档.md 第4.5节）：
 * - LEVEL_1 一级返佣：20%（直接邀请人，即 inviterId）
 * - LEVEL_2 二级返佣：2%（邀请人的邀请人，即 level2InviterId）
 * - LEVEL_3 三级返佣：1%（邀请人的邀请人的邀请人，即 level3InviterId）
 * 
 * 触发条件（依据：开发文档.md 第4.5节）：
 * - 仅首次购买付费产品（product.type=PAID）时触发返佣
 * - 用户 firstPurchaseDone=false 时购买付费产品才触发
 * - 触发后设置 user.firstPurchaseDone=true
 * 
 * 返佣比例配置（禁止硬编码）：
 * - commission_level1_rate：一级返佣比例（默认 20）
 * - commission_level2_rate：二级返佣比例（默认 2）
 * - commission_level3_rate：三级返佣比例（默认 1）
 * 
 * 返佣跳级规则（依据：开发文档.md 第16.4节）：
 * - 上级用户被封禁时跳过该级，不发放返佣给被封禁用户
 * - 跳过后不向上传递（不会跳到更上一级）
 * - 后台扣减用户余额时，已发放的返佣不收回
 * 
 * 示例：A邀请B，B邀请C。B被封禁，C首购时：
 * - A获得三级返佣（1%）
 * - B不获得返佣（被封禁）
 */
model CommissionRecord {
  id              Int             @id @default(autoincrement())
  
  // === 收佣用户 ===
  receiverId      Int                                             // 收佣用户ID
  receiver        User            @relation("CommissionReceiver", fields: [receiverId], references: [id])
  
  // === 贡献用户（触发返佣的下级）===
  sourceUserId    Int                                             // 贡献用户ID（购买产品的用户）
  sourceUser      User            @relation("CommissionSource", fields: [sourceUserId], references: [id])
  
  // === 关联持仓订单 ===
  positionOrderId Int                                             // 触发返佣的持仓订单ID
  positionOrder   PositionOrder   @relation(fields: [positionOrderId], references: [id])
  
  // === 返佣信息（依据：开发文档.md 第4.5节）===
  level           CommissionLevel                                 // 返佣级别（LEVEL_1/LEVEL_2/LEVEL_3）
  rate            Decimal         @db.Decimal(5, 2)               // 实际返佣比例（从 GlobalConfig 读取）
  baseAmount      Decimal         @db.Decimal(15, 2)              // 产品价格（计算基数）
  amount          Decimal         @db.Decimal(15, 2)              // 返佣金额 = baseAmount × rate / 100
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // === 索引（依据：开发文档.md 第14.0.5节 + 00.3-开发规范.md 第VI节）===
  @@index([receiverId], map: "idx_commission_record_receiver_id")           // 收佣用户查询
  @@index([sourceUserId], map: "idx_commission_record_source_user_id")      // 来源用户查询
  @@index([positionOrderId], map: "idx_commission_record_position_order_id") // 关联订单查询
  @@index([createdAt], map: "idx_commission_record_created_at")             // 时间范围查询
  @@map("commission_records")
}

/**
 * 返佣级别枚举
 * @description 三级返佣的级别定义，禁止自创级别
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.5节 - CommissionLevel枚举
 * @depends 开发文档/开发文档.md 第4.5节 - 团队返佣
 * 
 * 默认返佣比例（可通过 GlobalConfig 配置）：
 * - LEVEL_1：一级 20%
 * - LEVEL_2：二级 2%
 * - LEVEL_3：三级 1%
 */
enum CommissionLevel {
  LEVEL_1   // 一级返佣（20%，直接邀请人）
  LEVEL_2   // 二级返佣（2%，邀请人的邀请人）
  LEVEL_3   // 三级返佣（1%，邀请人的邀请人的邀请人）
}

