/**
 * 支付通道配置表
 * @file 支付通道模块数据库 Schema
 * @description 支付通道配置，支持 LWPAY/UZPAY 等多个通道，包含凭证配置、开关配置、状态监控、统计数据
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.4节 - PaymentChannel表
 * @depends 开发文档/05-后端服务/05.2-支付通道集成.md - 了解LWPAY和UZPAY通道差异
 * @depends 开发文档/附录/lwpay.md - LWPAY通道接口规范
 * @depends 开发文档/附录/uzpay.md - UZPAY通道接口规范
 * 
 * 通道差异对比（依据：lwpay.md + uzpay.md）：
 * | 项目         | LWPAY                          | UZPAY                  |
 * |-------------|--------------------------------|------------------------|
 * | 签名结果     | 大写 toUpperCase()              | 小写 toLowerCase()      |
 * | 成功回调响应 | OK                              | success                |
 * | 代收成功判断 | returncode='00' && refCode='1' | tradeResult='1'        |
 * | 代付成功判断 | returncode='00' && refCode='1' | tradeResult='1'        |
 * | 代收/代付密钥 | 共用同一密钥                    | 分开两个密钥（重要！）  |
 * 
 * 核心业务规则：
 * 1. 代收（payEnabled）可同时启用多个通道，用户可选择
 * 2. 代付（transferEnabled）同一时间只能启用一个通道（程序需校验）
 * 3. UZPAY 的代收密钥（paySecretKey）和代付密钥（transferSecretKey）不同，切勿混淆
 * 4. 通道状态（channelStatus）用于健康监控和自动切换
 * 5. 统计数据用于后台监控和报表
 */
model PaymentChannel {
  id                  Int       @id @default(autoincrement())
  code                String    @unique @db.VarChar(50)        // 通道代码：LWPAY / UZPAY
  name                String    @db.VarChar(100)               // 前端显示名称
  
  // === 凭证配置（依据：lwpay.md + uzpay.md）===
  merchantId          String    @db.VarChar(100)               // 商户号
  paySecretKey        String    @db.Text                       // 代收密钥
  transferSecretKey   String    @db.Text                       // 代付密钥（注意：UZPAY两者不同）
  gatewayUrl          String    @db.VarChar(500)               // 网关地址
  bankCode            String?   @db.VarChar(50)                // 银行编码（LWPAY:901）
  payType             String?   @db.VarChar(20)                // 支付类型（UZPAY: 1220/1221）
  
  // === 通道费率配置（仅用于后台报表展示，不影响用户端）===
  payFeeRate          Decimal   @default(0) @db.Decimal(5, 2)  // 代收点位（百分比，如 3.50 表示 3.50%）
  transferFeeRate     Decimal   @default(0) @db.Decimal(5, 2)  // 代付点位（百分比，如 2.00 表示 2.00%）
  
  // === 开关配置 ===
  payEnabled          Boolean   @default(false)                // 代收开关（可多开）
  transferEnabled     Boolean   @default(false)                // 代付开关（只能单开，程序需校验）
  
  // === 通道状态监控（依据：02.1-数据库设计.md 第2.4节 + 04.7.1-支付通道管理页.md）===
  channelStatus       ChannelStatus @default(NORMAL)           // 通道当前状态
  lastCheckAt         DateTime?                                // 最后一次状态检测时间
  consecutiveFailures Int       @default(0)                    // 连续失败次数（用于自动切换判断）
  hourlySuccessRate   Decimal?  @db.Decimal(5, 2)              // 近1小时成功率（0.00 ~ 100.00）
  weeklySuccessRate   Decimal?  @db.Decimal(5, 2)              // 近7天成功率（0.00 ~ 100.00）
  avgResponseTime     Int?                                     // 平均响应时间（毫秒）
  
  // === 通道余额（依据：04.7.1-支付通道管理页.md 第3.5节）===
  balance             Decimal?  @db.Decimal(15, 2)             // 通道当前余额
  balanceUpdatedAt    DateTime?                                // 余额最后更新时间
  
  // === 统计数据（定时任务更新，依据：02.1-数据库设计.md 第2.4节）===
  todayRecharge       Decimal   @default(0) @db.Decimal(15, 2) // 今日充值金额
  todayWithdraw       Decimal   @default(0) @db.Decimal(15, 2) // 今日提现金额
  yesterdayRecharge   Decimal   @default(0) @db.Decimal(15, 2) // 昨日充值金额
  yesterdayWithdraw   Decimal   @default(0) @db.Decimal(15, 2) // 昨日提现金额
  totalRecharge       Decimal   @default(0) @db.Decimal(15, 2) // 总充值金额
  totalWithdraw       Decimal   @default(0) @db.Decimal(15, 2) // 总提现金额
  
  // === 限额配置 ===
  minAmount           Decimal?  @db.Decimal(15, 2)             // 最小金额
  maxAmount           Decimal?  @db.Decimal(15, 2)             // 最大金额
  
  // === 回调白名单（依据：05.2-支付通道集成.md - UZPAY回调IP: 18.143.234.124）===
  callbackIps         String?   @db.Text                       // 回调IP白名单（逗号分隔，如"18.143.234.124,1.2.3.4"）
  
  // === 扩展配置 ===
  extraConfig         Json?                                    // 扩展配置（预留字段）
  
  // === 排序与备注 ===
  sortOrder           Int       @default(0)                    // 排序
  remark              String?   @db.VarChar(500)               // 备注
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // === 关联关系 ===
  rechargeOrders      RechargeOrder[]                          // 充值订单
  withdrawOrders      WithdrawOrder[]                          // 提现订单
  
  @@index([payEnabled], map: "idx_payment_channel_pay_enabled")
  @@index([transferEnabled], map: "idx_payment_channel_transfer_enabled")
  @@index([channelStatus], map: "idx_payment_channel_status")
  @@map("payment_channels")
}

/**
 * 通道状态枚举
 * @description 支付通道的健康状态，用于监控和自动切换
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.4节 - ChannelStatus枚举
 * 
 * 状态说明：
 * - NORMAL: 正常运行，成功率正常
 * - WARNING: 警告状态，成功率下降但仍可用
 * - ERROR: 异常状态，建议切换到其他通道
 * 
 * 自动状态判断规则（建议）：
 * - hourlySuccessRate >= 95% → NORMAL
 * - 80% <= hourlySuccessRate < 95% → WARNING
 * - hourlySuccessRate < 80% 或 consecutiveFailures >= 5 → ERROR
 */
enum ChannelStatus {
  NORMAL    // 正常
  WARNING   // 警告（成功率下降）
  ERROR     // 异常
}

// ================================
// 配置相关表
// ================================

/**
 * 全局配置表
 * @description 系统全局配置，使用 key-value 结构存储，value 为 JSON 类型
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.7节 - GlobalConfig表
 * @depends 开发文档/开发文档.md 第2节 - 全局与基础配置
 * 
 * ⚠️ 核心原则：配置化优先，禁止硬编码
 * - 所有业务配置存数据库，后台可动态修改
 * - 时区配置从 system_timezone 读取，禁止硬编码
 * - 返佣比例从 commission_level*_rate 读取，禁止硬编码
 * 
 * 核心配置项分类：
 * 1. 基础配置：site_name, site_domain, site_logo_url, currency_symbol 等
 * 2. 时区配置：system_timezone, timezone_display_name
 * 3. 提现配置：withdraw_fee_percent, withdraw_limit_daily, withdraw_time_range 等
 * 4. 充值配置：recharge_presets, recharge_min_amount, recharge_max_amount 等
 * 5. 返佣配置：commission_level1_rate, commission_level2_rate, commission_level3_rate
 * 6. 版本管理：global_config_version, texts_version, timezone_version 等
 * 7. 安全配置：rate_limit_*, token_expires_days 等
 * 8. 免审核配置：auto_approve_enabled, auto_approve_threshold 等
 * 
 * 配置版本管理说明（依据：开发文档.md 第1.0.2节）：
 * - 版本号：单调递增整数，用于快速判断是否有更新
 * - 时间戳：ISO 8601 格式，用于解决多实例版本号冲突问题
 * - 双重校验逻辑：前端检测时同时比对版本号和时间戳
 */
model GlobalConfig {
  id              Int               @id @default(autoincrement())
  key             String            @unique @db.VarChar(100)    // 配置键（唯一）
  value           Json                                          // 配置值（JSON类型，支持各种数据结构）
  description     String?           @db.VarChar(500)            // 配置说明
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@map("global_configs")
}

/**
 * 文案配置表
 * @description 前端文案配置，支持变量替换，实现文案配置化
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.7节 - TextConfig表
 * @depends 开发文档/开发文档.md 第12.1节 - 语言与文案配置系统
 * 
 * 核心业务规则：
 * 1. key 使用点分隔命名：如 btn.confirm, nav.home, toast.success
 * 2. category 用于分类管理：nav/btn/label/toast/error/...
 * 3. variables 定义可替换变量：如 ["amount", "currency"]
 * 4. 变量替换示例：value="余额：{amount} {currency}" → "余额：$ 100.000"
 * 
 * ⚠️ 语言规范（依据：00.3-开发规范.md）：
 * - 用户前端文案：西班牙语
 * - 后台管理界面：中文
 * - 默认值/文案必须是西班牙语
 */
model TextConfig {
  id              Int               @id @default(autoincrement())
  key             String            @unique @db.VarChar(100)    // 文案键（唯一），如 btn.confirm
  value           String            @db.Text                    // 文案内容（西班牙语）
  category        String            @db.VarChar(50)             // 分类：nav/btn/label/toast/error/...
  description     String?           @db.VarChar(500)            // 说明（中文注释）
  variables       Json?                                         // 变量列表，如 ["amount", "currency"]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引 ===
  @@index([category], map: "idx_text_config_category")
  @@map("text_configs")
}

/**
 * 文案版本记录表
 * @description 记录文案修改历史，用于版本追溯和回滚
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.16节 - TextConfigVersion表
 * 
 * 核心业务规则：
 * 1. 每次修改文案时生成一条版本记录
 * 2. version 对应 GlobalConfig.texts_version
 * 3. oldValue 为修改前的值，newValue 为修改后的值
 * 4. operatorId/operatorName 记录操作人信息
 */
model TextConfigVersion {
  id              Int               @id @default(autoincrement())
  
  // === 版本信息 ===
  version         Int                                               // 版本号（对应 GlobalConfig.texts_version）
  textKey         String            @db.VarChar(100)                // 文案key
  oldValue        String?           @db.Text                        // 修改前的值
  newValue        String            @db.Text                        // 修改后的值
  
  // === 操作人信息 ===
  operatorId      Int                                               // 操作管理员ID
  operatorName    String            @db.VarChar(50)                 // 操作管理员名称
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引（依据：02.1-数据库设计.md 第3.3节）===
  @@index([textKey], map: "idx_text_config_version_text_key")
  @@index([version], map: "idx_text_config_version_version")
  @@map("text_config_versions")
}

/**
 * 银行列表表
 * @description 系统支持的银行列表，用于用户绑卡时选择和校验
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.12节 - Bank表
 * 
 * 业务规则（依据：开发文档.md 第16.10节）：
 * - 禁用银行后，该银行从用户绑卡的银行选择列表中移除
 * - 已绑定被禁用银行的用户，使用该银行卡申请提现时拒绝申请
 * - 历史提现记录不受影响，已完成的提现记录正常显示
 */
model Bank {
  id          Int        @id @default(autoincrement())
  code        String     @unique @db.VarChar(20)              // 银行编码（如 COP001）
  name        String     @db.VarChar(100)                     // 银行名称
  isActive    Boolean    @default(true)                       // 是否启用
  sortOrder   Int        @default(0)                          // 排序
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // === 关联关系 ===
  bankCards   BankCard[]                                      // 使用此银行的银行卡
  
  @@map("banks")
}

// ================================
// 内容管理表
// ================================

/**
 * 轮播图表
 * @description 首页轮播图配置，支持多种跳转类型和定时上下架
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.8节 - Banner表
 * 
 * 核心业务规则：
 * 1. linkType 支持四种跳转类型：NONE/INTERNAL/EXTERNAL/PRODUCT
 * 2. linkType=PRODUCT 时，productId 必填
 * 3. linkType=INTERNAL/EXTERNAL 时，linkUrl 必填
 * 4. 支持定时上下架：startAt/endAt 配合 isActive 使用
 * 5. 按 sortOrder 升序排列，数值越小越靠前
 */
model Banner {
  id              Int               @id @default(autoincrement())
  
  // === 图片配置 ===
  imageUrl        String            @db.VarChar(500)              // Banner图片URL
  
  // === 跳转配置（依据：开发文档.md 第2.8节）===
  linkType        BannerLinkType    @default(NONE)                // 跳转类型
  linkUrl         String?           @db.VarChar(500)              // 跳转链接（linkType=INTERNAL/EXTERNAL时使用）
  productId       Int?                                            // 产品ID（linkType=PRODUCT时使用）
  
  // === 定时上下架配置 ===
  startAt         DateTime?                                       // 生效开始时间
  endAt           DateTime?                                       // 生效结束时间
  
  // === 状态与排序 ===
  isActive        Boolean           @default(true)                // 是否启用
  sortOrder       Int               @default(0)                   // 排序（数值越小越靠前）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引 ===
  @@index([isActive], map: "idx_banner_is_active")
  @@index([sortOrder], map: "idx_banner_sort_order")
  @@map("banners")
}

/**
 * Banner跳转类型枚举
 * @description Banner点击后的跳转行为类型，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.8节 - BannerLinkType枚举
 * 
 * 跳转规则：
 * - NONE: 不跳转，仅展示
 * - INTERNAL: 跳转到内部页面，使用 linkUrl
 * - EXTERNAL: 跳转到外部链接，使用 linkUrl
 * - PRODUCT: 跳转到产品详情页，使用 productId
 */
enum BannerLinkType {
  NONE       // 无跳转
  URL        // URL跳转（外部链接）
  PRODUCT    // 产品详情
}

/**
 * 系统公告表
 * @description 系统公告管理，支持定向发送、弹窗频率控制、自定义按钮配置
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.8节 - Announcement表
 * @depends 开发文档/开发文档.md 第13.10.2节 - 公告管理
 * 
 * 核心业务规则：
 * 1. targetType=ALL 时发送给所有用户
 * 2. targetType=SPECIFIC 时，targetUserIds 必填，仅指定用户可见
 * 3. popupFrequency 控制弹窗显示频率
 * 4. buttons 支持自定义按钮配置
 * 5. 支持定时上下架：startAt/endAt 配合 isActive 使用
 * 
 * buttons 配置格式示例：
 * [
 *   { "text": "确认", "type": "primary", "action": "close" },
 *   { "text": "查看详情", "type": "link", "action": "navigate", "url": "/product/1" }
 * ]
 */
model Announcement {
  id              Int                 @id @default(autoincrement())
  
  // === 公告内容 ===
  title           String              @db.VarChar(200)              // 公告标题
  content         String              @db.Text                      // 公告内容（富文本）
  imageUrl        String?             @db.VarChar(500)              // 公告顶部图片
  
  // === 定向发送配置（依据：开发文档.md 第13.10.2节）===
  targetType      AnnouncementTarget  @default(ALL)                 // 目标用户类型
  targetUserIds   Json?                                             // 指定用户ID列表（targetType=SPECIFIC时）
  
  // === 弹窗频率控制 ===
  popupFrequency  PopupFrequency      @default(ONCE)                // 弹窗显示频率
  
  // === 自定义按钮配置 ===
  buttons         Json?                                             // 按钮配置 [{text, type, action, url}]
  
  // === 定时上下架配置 ===
  startAt         DateTime?                                         // 生效开始时间
  endAt           DateTime?                                         // 生效结束时间
  
  // === 状态与排序 ===
  isActive        Boolean             @default(true)                // 是否启用
  sortOrder       Int                 @default(0)                   // 排序
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // === 关联关系 ===
  readRecords     AnnouncementRead[]                                // 已读记录
  
  // === 索引（依据：02.1-数据库设计.md 第3.2节）===
  @@index([isActive], map: "idx_announcement_is_active")
  @@index([startAt], map: "idx_announcement_start_at")
  @@index([endAt], map: "idx_announcement_end_at")
  @@map("announcements")
}

/**
 * 公告目标用户枚举
 * @description 公告发送目标类型，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.8节 - AnnouncementTarget枚举
 */
enum AnnouncementTarget {
  ALL         // 全部用户
  SPECIFIC    // 指定用户
}

/**
 * 弹窗频率枚举
 * @description 公告弹窗显示频率，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.8节 - PopupFrequency枚举
 * 
 * 说明：
 * - ONCE: 每个用户仅显示一次，已读后不再弹出
 * - EVERY_LOGIN: 每次登录时显示
 * - DAILY: 每天首次打开时显示一次
 */
enum PopupFrequency {
  ONCE          // 每用户仅一次
  EVERY_LOGIN   // 每次登录
  DAILY         // 每天一次
}

/**
 * 公告已读记录表
 * @description 记录用户已读公告，用于控制弹窗显示
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.17节 - AnnouncementRead表
 * 
 * 核心业务规则：
 * 1. 唯一索引 [announcementId, userId] 防止重复已读记录
 * 2. 配合 Announcement.popupFrequency 实现弹窗频率控制
 * 3. readAt 记录用户首次阅读时间
 */
model AnnouncementRead {
  id              Int               @id @default(autoincrement())
  
  // === 公告关联 ===
  announcementId  Int                                               // 公告ID
  announcement    Announcement      @relation(fields: [announcementId], references: [id])
  
  // === 用户关联 ===
  userId          Int                                               // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 已读信息 ===
  readAt          DateTime          @default(now())                 // 首次阅读时间
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 唯一索引（防重复已读，关键约束）===
  @@unique([announcementId, userId], map: "unique_announcement_read_announcement_user")
  
  // === 索引 ===
  @@index([userId], map: "idx_announcement_read_user_id")
  @@map("announcement_reads")
}

/// 客服链接表
model ServiceLink {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100) /// 名称
  type        String    @db.VarChar(20) /// 类型 whatsapp/telegram/line
  url         String    @db.VarChar(255) /// 链接
  iconUrl     String?   @db.VarChar(255) /// 图标URL
  sortOrder   Int       @default(0) /// 排序
  isActive    Boolean   @default(true) /// 是否启用
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("service_links")
}

/// 页面配置表
/**
 * 页面配置表
 * @description 存储各页面的配置信息，支持后台动态配置
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.14节 - PageConfig表
 * 
 * 页面类型示例：
 * - home: 首页配置
 * - profile: 个人中心配置
 * - product: 产品页配置
 */
model PageConfig {
  id              Int               @id @default(autoincrement())
  
  // === 配置信息 ===
  pageType        String            @unique @db.VarChar(50)         // 页面类型：home / profile / product
  config          Json                                              // 页面配置JSON
  version         Int               @default(1)                     // 配置版本号
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@map("page_configs")
}

/**
 * 页面内容配置表
 * @description 存储静态页面内容，如关于我们、客服链接、邀请海报等
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.14节 - PageContent表
 * 
 * 页面ID示例：
 * - about_us: 关于我们
 * - service_links: 客服链接
 * - poster: 邀请海报配置
 */
model PageContent {
  id              Int               @id @default(autoincrement())
  
  // === 内容信息 ===
  pageId          String            @unique @db.VarChar(50)         // 页面ID
  content         Json                                              // 页面内容JSON
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@map("page_contents")
}

/**
 * 交互动画配置表
 * @description 控制前端交互动画效果的全局配置
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.15节 - AnimationConfig表
 * 
 * 核心配置项：
 * - animationEnabled: 全局动画开关
 * - animationSpeed: 动画速度倍率
 * - reducedMotion: 减弱动画模式（无障碍访问）
 * - celebrationEffect: 庆祝效果（如签到成功撒花）
 */
model AnimationConfig {
  id              Int               @id @default(autoincrement())
  
  // === 动画配置 ===
  animationEnabled    Boolean       @default(true)                  // 全局动画开关
  animationSpeed      Decimal       @default(1) @db.Decimal(3, 2)   // 动画速度倍率（0.5~2.0）
  reducedMotion       Boolean       @default(false)                 // 减弱动画模式（无障碍）
  celebrationEffect   Boolean       @default(true)                  // 庆祝效果开关
  pageTransition      Boolean       @default(true)                  // 页面过渡动画
  skeletonLoading     Boolean       @default(true)                  // 骨架屏加载
  pullToRefresh       Boolean       @default(true)                  // 下拉刷新动画
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@map("animation_configs")
}

// ================================
// 活动相关表
// ================================

/**
 * 活动配置表
 * @description 系统活动配置，使用 JSON 存储活动配置（奖励档位等）
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.13节 - Activity表
 * 
 * 活动代码说明（禁止自创）：
 * - NORMAL_SIGNIN: 普通用户3天签到
 * - SVIP_SIGNIN: SVIP每日签到
 * - INVITE_REWARD: 拉新裂变活动
 * - COLLECTION_BONUS: 连单奖励活动
 * 
 * 配置示例：
 * NORMAL_SIGNIN: { dailyReward: 1, windowDays: 7, targetDays: 3 }
 * SVIP_SIGNIN: { rewards: { SVIP1: 2, SVIP2: 4, ... } }
 * INVITE_REWARD: { tiers: [{ count: 1, reward: 10 }, { count: 10, reward: 58 }, ...] }
 * COLLECTION_BONUS: { tiers: [{ products: ["VIP1", "VIP2"], reward: 58 }, ...] }
 */
model Activity {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)              // 活动标识：SVIP_SIGNIN/INVITE_REWARD/COLLECTION_BONUS/NORMAL_SIGNIN
  name        String    @db.VarChar(100)                     // 活动名称
  description String?   @db.Text                             // 活动说明
  icon        String?   @db.VarChar(500)                     // 活动图标
  
  config      Json                                           // 活动配置（奖励档位等）
  
  isActive    Boolean   @default(true)                       // 是否启用
  sortOrder   Int       @default(0)                          // 排序
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("activities")
}

/**
 * 签到记录表
 * @description 记录用户签到行为，支持普通签到和SVIP签到两种类型
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.6节 - SignInRecord表
 * @depends 开发文档/开发文档.md 第9节 - 营销活动系统
 * 
 * 核心业务规则：
 * 1. 唯一索引 [userId, signType, signDate] 防止同一用户同一天同一类型重复签到
 * 2. SVIP用户可同时领取普通签到和SVIP签到两份奖励
 * 3. 普通签到奖励金额从 Activity.config.dailyReward 读取（NORMAL_SIGNIN活动）
 * 4. SVIP签到奖励金额从 Activity.config.rewards[SVIP等级] 读取（SVIP_SIGNIN活动）
 * 
 * 签到规则补充（依据：开发文档.md 第16.6节）：
 * - 普通用户3天签到：从注册日期开始计算，注册当天为第1天
 * - SVIP用户双签到：SVIP用户可同时领取普通签到和SVIP签到两份奖励
 * - 示例：SVIP3用户每日可领：普通签到 1 + SVIP签到 8 = 共 9
 */
model SignInRecord {
  id              Int               @id @default(autoincrement())
  
  // === 用户关联 ===
  userId          Int                                           // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 签到信息 ===
  signType        SignInType                                    // 签到类型：NORMAL=普通签到 / SVIP=SVIP签到
  signDate        DateTime          @db.Date                    // 签到日期（系统时区日期）
  amount          Decimal           @db.Decimal(15, 2)          // 签到奖励金额
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 唯一索引（防重复签到，关键约束）===
  @@unique([userId, signType, signDate], map: "unique_sign_in_user_type_date")
  
  // === 索引 ===
  @@index([userId], map: "idx_sign_in_record_user_id")
  @@index([signDate], map: "idx_sign_in_record_sign_date")
  @@map("sign_in_records")
}

/**
 * 签到类型枚举
 * @description 签到类型，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.6节 - SignInType枚举
 * 
 * 说明：
 * - NORMAL: 普通签到，每日可签到一次
 * - SVIP: SVIP签到，SVIP用户专属，可与普通签到叠加
 */
enum SignInType {
  NORMAL    // 普通签到
  SVIP      // SVIP签到（可叠加）
}

/**
 * 活动奖励领取记录表
 * @description 记录用户领取活动奖励的记录，用于防止重复领取
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.6节 - ActivityReward表
 * 
 * 核心业务规则：
 * 1. 唯一索引 [userId, activityCode, rewardLevel] 防止同一用户重复领取同一档位奖励
 * 2. 活动代码必须使用系统定义的：INVITE_REWARD, COLLECTION_BONUS
 * 3. rewardLevel 对应活动配置中的阶梯档位
 * 
 * 活动代码说明（禁止自创）：
 * - INVITE_REWARD: 拉新裂变活动，rewardLevel 对应有效邀请人数档位
 * - COLLECTION_BONUS: 连单奖励活动，rewardLevel 对应产品组合档位
 */
model ActivityReward {
  id              Int               @id @default(autoincrement())
  
  // === 用户关联 ===
  userId          Int                                           // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 奖励信息 ===
  activityCode    String            @db.VarChar(50)             // 活动代码：INVITE_REWARD / COLLECTION_BONUS
  rewardLevel     Int                                           // 档位等级（如拉新裂变的1人/10人/30人档位）
  amount          Decimal           @db.Decimal(15, 2)          // 奖励金额
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 唯一索引（防重复领取，关键约束）===
  @@unique([userId, activityCode, rewardLevel], map: "unique_activity_reward_user_activity_level")
  
  // === 索引 ===
  @@index([userId], map: "idx_activity_reward_user_id")
  @@index([activityCode], map: "idx_activity_reward_activity_code")
  @@map("activity_rewards")
}

/**
 * 有效邀请记录表
 * @description 记录拉新裂变活动的有效邀请，用于计算阶梯奖励
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.6节 - ValidInvitation表
 * @depends 开发文档/开发文档.md 第9节活动2 - 有效邀请定义
 * 
 * ⚠️ 重要：有效邀请与返佣是两套独立机制，切勿混淆！
 * 
 * 对比说明（依据：开发文档.md 第8节）：
 * | 对比项       | 有效邀请（拉新裂变活动）     | 返佣（三级分销）          |
 * |-------------|---------------------------|------------------------|
 * | 用途        | 计算拉新裂变活动的阶梯奖励   | 计算三级分销的返佣金额    |
 * | 触发条件    | 充值后购买产品 或 完成3天签到 | 首次购买付费产品         |
 * | 计算基数    | 有效邀请人数               | 产品价格                |
 * | 奖励发放    | 邀请人手动领取阶梯奖励      | 返佣自动到账上级余额     |
 * 
 * 核心业务规则：
 * 1. 唯一索引 [inviterId, inviteeId] 确保每个被邀请人最多算1个有效邀请
 * 2. 有效邀请只计1次，即使被邀请人满足多个条件
 * 3. validType 记录触发有效邀请的类型
 * 4. isRewardClaimed 用于标记该邀请是否已计入奖励领取
 */
model ValidInvitation {
  id              Int               @id @default(autoincrement())
  
  // === 邀请人信息 ===
  inviterId       Int                                           // 邀请人ID
  inviter         User              @relation("ValidInvitationInviter", fields: [inviterId], references: [id])
  
  // === 被邀请人信息 ===
  inviteeId       Int                                           // 被邀请人ID
  invitee         User              @relation("ValidInvitationInvitee", fields: [inviteeId], references: [id])
  
  // === 有效邀请信息 ===
  validType       ValidInviteType                               // 有效类型
  validAt         DateTime                                      // 生效时间
  
  // === 奖励关联 ===
  isRewardClaimed Boolean           @default(false)             // 是否已计入奖励领取
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 唯一索引（每个被邀请人最多算1个有效邀请，关键约束）===
  @@unique([inviterId, inviteeId], map: "unique_valid_invitation_inviter_invitee")
  
  // === 索引 ===
  @@index([inviterId], map: "idx_valid_invitation_inviter_id")
  @@index([inviteeId], map: "idx_valid_invitation_invitee_id")
  @@index([validAt], map: "idx_valid_invitation_valid_at")
  @@map("valid_invitations")
}

/**
 * 有效邀请类型枚举
 * @description 有效邀请的触发类型，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.6节 - ValidInviteType枚举
 * 
 * 说明：
 * - RECHARGE_PURCHASE: 被邀请人充值后购买了产品
 * - COMPLETE_SIGNIN: 被邀请人完成了3天签到任务
 */
enum ValidInviteType {
  RECHARGE_PURCHASE   // 充值购买
  COMPLETE_SIGNIN     // 完成3天签到
}

// ================================
// 通知相关表
// ================================

/**
 * 站内通知表
 * @description 系统与用户沟通的站内通知，包括充值成功、提现结果、收益到账等
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.11节 - Notification表
 * 
 * 核心业务规则：
 * 1. type 使用 NotificationType 枚举，禁止自创类型
 * 2. isRead 标记是否已读，readAt 记录阅读时间
 * 3. content 支持富文本内容
 * 4. 按 createdAt 降序排列显示（最新在前）
 * 
 * 通知类型说明：
 * - 充值：RECHARGE_SUCCESS
 * - 提现：WITHDRAW_APPROVED, WITHDRAW_COMPLETED, WITHDRAW_REJECTED, WITHDRAW_FAILED
 * - 收益：INCOME_RECEIVED, COMMISSION_RECEIVED
 * - 活动：SIGN_IN_REWARD, ACTIVITY_REWARD
 * - 系统：SYSTEM_ANNOUNCEMENT
 */
model Notification {
  id              Int               @id @default(autoincrement())
  
  // === 用户关联 ===
  userId          Int                                               // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 通知内容 ===
  title           String            @db.VarChar(200)                // 通知标题
  content         String            @db.Text                        // 通知内容（支持富文本）
  type            NotificationType                                  // 通知类型
  
  // === 已读状态 ===
  isRead          Boolean           @default(false)                 // 是否已读
  readAt          DateTime?                                         // 阅读时间
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引（依据：02.1-数据库设计.md 第3.2节）===
  @@index([userId], map: "idx_notification_user_id")
  @@index([isRead], map: "idx_notification_is_read")
  @@index([createdAt], map: "idx_notification_created_at")
  @@map("notifications")
}

/**
 * 通知类型枚举
 * @description 站内通知的类型分类，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.11节 - NotificationType枚举
 * 
 * 类型说明：
 * - RECHARGE_SUCCESS: 充值成功通知
 * - WITHDRAW_APPROVED: 提现审核通过通知
 * - WITHDRAW_COMPLETED: 提现完成通知
 * - WITHDRAW_REJECTED: 提现被拒绝通知
 * - WITHDRAW_FAILED: 提现失败通知
 * - INCOME_RECEIVED: 收益到账通知
 * - COMMISSION_RECEIVED: 返佣到账通知
 * - SIGN_IN_REWARD: 签到奖励到账通知
 * - ACTIVITY_REWARD: 活动奖励到账通知
 * - SYSTEM_ANNOUNCEMENT: 系统公告通知
 */
enum NotificationType {
  RECHARGE_SUCCESS        // 充值成功
  WITHDRAW_APPROVED       // 提现审核通过
  WITHDRAW_COMPLETED      // 提现完成
  WITHDRAW_REJECTED       // 提现被拒绝
  WITHDRAW_FAILED         // 提现失败
  INCOME_RECEIVED         // 收益到账
  COMMISSION_RECEIVED     // 返佣到账
  SIGN_IN_REWARD          // 签到奖励到账
  ACTIVITY_REWARD         // 活动奖励到账
  SYSTEM_ANNOUNCEMENT     // 系统公告
  SVIP_DAILY_REWARD       // SVIP每日奖励
  WEEKLY_SALARY_CLAIMED   // 周薪领取
  PRIZE_POOL_CLAIMED      // 奖池领取
  SPIN_WHEEL_WIN          // 转盘中奖
  FINANCIAL_PRINCIPAL     // 理财本金返还
  COMMUNITY_POST_APPROVED // 帖子审核通过
  COMMUNITY_POST_REJECTED // 帖子审核拒绝
  COMMUNITY_REWARD        // 社区奖励
}

// ================================
// 用户在线状态相关表
// ================================

/**
 * 用户在线状态表
 * @description 记录用户在线状态，用于后台实时监控
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.18节 - UserOnlineStatus表
 * @depends 开发文档/开发文档.md 第13.23节 - 用户在线状态
 * 
 * 核心业务规则：
 * 1. userId 唯一，每个用户只有一条在线状态记录
 * 2. 心跳间隔从 GlobalConfig.heartbeat_interval 读取（默认60秒）
 * 3. 超时时间从 GlobalConfig.heartbeat_timeout 读取（默认120秒）
 * 4. lastHeartbeat > now - heartbeat_timeout 判定为在线
 * 
 * 在线判断规则（可配置化，禁止硬编码）：
 * - isOnline = (当前时间 - lastHeartbeat) < heartbeat_timeout
 */
model UserOnlineStatus {
  id              Int               @id @default(autoincrement())
  
  // === 用户关联（唯一）===
  userId          Int               @unique                         // 用户ID
  user            User              @relation(fields: [userId], references: [id])
  
  // === 在线状态 ===
  lastHeartbeat   DateTime                                          // 最后心跳时间
  isOnline        Boolean           @default(true)                  // 是否在线（冗余字段，定时任务更新）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引 ===
  @@index([isOnline], map: "idx_user_online_status_is_online")
  @@index([lastHeartbeat], map: "idx_user_online_status_last_heartbeat")
  @@map("user_online_statuses")
}

/**
 * 在线统计快照表
 * @description 定时记录在线人数快照，用于统计分析
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.18节 - OnlineStatSnapshot表
 * 
 * 核心业务规则：
 * 1. 定时任务每隔一段时间（如5分钟）生成一条快照
 * 2. snapshotAt 记录快照时间
 * 3. onlineCount 记录当时的在线人数
 */
model OnlineStatSnapshot {
  id              Int               @id @default(autoincrement())
  
  // === 快照信息 ===
  snapshotAt      DateTime                                          // 快照时间
  onlineCount     Int                                               // 在线人数
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引 ===
  @@index([snapshotAt], map: "idx_online_stat_snapshot_snapshot_at")
  @@map("online_stat_snapshots")
}

// ================================
// 管理员相关表（封控与日志模块）
// ================================

/**
 * 管理员表
 * @description 后台管理员账号管理
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.9节 - Admin表
 * 
 * 核心业务规则：
 * 1. password 使用 bcrypt 单向哈希存储（不可逆，区别于用户密码的AES加密）
 * 2. 关联 AdminOperationLog 记录操作行为
 * 3. 关联 AdminLoginLog 记录登录行为
 * 
 * ⚠️ 安全要求：
 * - 密码必须使用 bcrypt 加密，禁止使用 AES
 * - bcrypt 是单向哈希，不可解密，只能通过比对验证
 */
model Admin {
  id              Int               @id @default(autoincrement())
  
  // === 基本信息 ===
  username        String            @unique @db.VarChar(50)         // 用户名
  password        String            @db.VarChar(255)                // bcrypt哈希（单向不可逆）
  nickname        String?           @db.VarChar(50)                 // 昵称
  
  // === 状态 ===
  isActive        Boolean           @default(true)                  // 是否启用
  
  // === 登录信息 ===
  lastLoginAt     DateTime?                                         // 最后登录时间
  lastLoginIp     String?           @db.VarChar(50)                 // 最后登录IP
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 关联关系（依据：02.1-数据库设计.md 第2.9节）===
  operationLogs   AdminOperationLog[]                               // 操作日志
  loginLogs       AdminLoginLog[]                                   // 登录日志
  giftCodes       GiftCode[]                                        // 创建的礼品码
  
  @@map("admins")
}

/**
 * 管理员操作日志表
 * @description 记录管理员在后台的所有操作行为，便于审计追溯
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.9节 - AdminOperationLog表
 * 
 * 核心业务规则：
 * 1. beforeData 记录操作前数据快照
 * 2. afterData 记录操作后数据快照
 * 3. 通过对比 before/after 可追溯完整变更历史
 * 4. module + action 组合定义操作类型
 * 
 * 操作模块示例：
 * - module: user, product, withdraw, recharge, config, admin, activity
 * 
 * 操作类型示例：
 * - action: create, update, delete, ban, unban, approve, reject, gift
 */
model AdminOperationLog {
  id              Int               @id @default(autoincrement())
  
  // === 管理员关联 ===
  adminId         Int                                               // 操作管理员ID
  admin           Admin             @relation(fields: [adminId], references: [id])
  
  // === 操作信息（依据：02.1-数据库设计.md 第2.9节）===
  module          String            @db.VarChar(50)                 // 操作模块（user/product/withdraw等）
  action          String            @db.VarChar(50)                 // 操作类型（create/update/delete等）
  targetType      String?           @db.VarChar(50)                 // 操作对象类型
  targetId        String?           @db.VarChar(50)                 // 操作对象ID
  
  // === 数据快照（关键字段，用于审计）===
  beforeData      Json?                                             // 操作前数据快照
  afterData       Json?                                             // 操作后数据快照
  
  // === 其他信息 ===
  ip              String?           @db.VarChar(50)                 // 操作IP
  remark          String?           @db.VarChar(500)                // 操作备注
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引（依据：02.1-数据库设计.md 第3.3节）===
  @@index([adminId], map: "idx_admin_operation_log_admin_id")
  @@index([module], map: "idx_admin_operation_log_module")
  @@index([createdAt], map: "idx_admin_operation_log_created_at")
  @@map("admin_operation_logs")
}

/**
 * 管理员登录日志表
 * @description 记录管理员登录行为，包括成功和失败的登录尝试
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.19节 - AdminLoginLog表
 * 
 * 核心业务规则：
 * 1. adminId 可为 null，登录失败时可能无法确定管理员
 * 2. username 记录尝试登录的用户名，用于追踪登录行为
 * 3. status 使用 LoginStatus 枚举，SUCCESS/FAILED
 * 4. failReason 记录登录失败原因
 */
model AdminLoginLog {
  id              Int               @id @default(autoincrement())
  
  // === 管理员关联（可为空，登录失败时可能无法确定）===
  adminId         Int?                                              // 管理员ID
  admin           Admin?            @relation(fields: [adminId], references: [id])
  
  // === 登录信息 ===
  username        String            @db.VarChar(50)                 // 尝试登录的用户名
  
  // === 设备信息 ===
  ip              String            @db.VarChar(50)                 // 登录IP
  ipLocation      String?           @db.VarChar(100)                // IP归属地（可选）
  userAgent       String?           @db.Text                        // 浏览器 User-Agent
  deviceInfo      String?           @db.VarChar(200)                // 解析后的设备信息
  
  // === 登录状态（依据：02.1-数据库设计.md 第2.19节）===
  status          LoginStatus       @default(SUCCESS)               // 登录状态
  failReason      String?           @db.VarChar(200)                // 失败原因（密码错误/账号禁用等）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引（依据：02.1-数据库设计.md 第3.3节）===
  @@index([adminId], map: "idx_admin_login_log_admin_id")
  @@index([username], map: "idx_admin_login_log_username")
  @@index([ip], map: "idx_admin_login_log_ip")
  @@index([createdAt], map: "idx_admin_login_log_created_at")
  @@map("admin_login_logs")
}

/**
 * 登录状态枚举
 * @description 登录结果状态，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.19节 - LoginStatus枚举
 */
enum LoginStatus {
  SUCCESS   // 登录成功
  FAILED    // 登录失败
}

/**
 * 用户登录日志表
 * @description 记录用户登录行为，包括成功和失败的登录尝试
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.1节 - UserLoginLog
 * 
 * 说明：
 * - userId 为可选字段，登录失败时可能无法确定用户
 * - phone 记录尝试登录的手机号，用于追踪登录行为
 * - success 为布尔值，表示登录是否成功
 */
model UserLoginLog {
  id              Int                 @id @default(autoincrement())
  userId          Int?                                    // 登录失败时可能无法确定用户
  phone           String              @db.VarChar(20)     // 尝试登录的手机号
  
  ip              String              @db.VarChar(50)
  ipLocation      String?             @db.VarChar(100)    // IP归属地（可选）
  userAgent       String?             @db.VarChar(500)
  deviceType      String?             @db.VarChar(20)     // mobile/desktop/tablet
  
  success         Boolean                                 // 登录是否成功
  failReason      String?             @db.VarChar(100)    // 失败原因：密码错误/账号封禁等
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  user            User?               @relation(fields: [userId], references: [id])
  
  @@index([userId], map: "idx_user_login_log_user_id")
  @@index([phone], map: "idx_user_login_log_phone")
  @@index([ip], map: "idx_user_login_log_ip")
  @@index([createdAt], map: "idx_user_login_log_created_at")
}


// ================================
// 安全相关表（封控与日志模块）
// ================================

/**
 * 黑名单表
 * @description 系统封控管理，支持多种封禁类型（手机号、IP、银行卡）
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.9节 - Blacklist表
 * 
 * 核心业务规则：
 * 1. 唯一索引 [type, value] 防止重复封禁同一对象
 * 2. type 支持三种封禁类型：PHONE/IP/BANK_CARD
 * 3. createdBy 记录操作管理员ID
 * 4. reason 记录封禁原因（可选）
 * 
 * 封禁效果：
 * - PHONE: 该手机号无法注册和登录
 * - IP: 该IP无法访问系统
 * - BANK_CARD: 该银行卡无法用于提现
 */
model Blacklist {
  id              Int               @id @default(autoincrement())
  
  // === 封禁信息（依据：开发文档.md 第2.9节）===
  type            BlacklistType                                     // 封禁类型
  value           String            @db.VarChar(100)                // 封禁值（手机号/IP/银行卡号）
  reason          String?           @db.VarChar(500)                // 封禁原因
  
  // === 操作信息 ===
  createdBy       Int                                               // 操作管理员ID
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 唯一索引（防重复封禁，关键约束）===
  @@unique([type, value], map: "unique_blacklist_type_value")
  
  // === 索引 ===
  @@index([type], map: "idx_blacklist_type")
  @@map("blacklists")
}

/**
 * 黑名单类型枚举
 * @description 封禁类型，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.9节 - BlacklistType枚举
 */
enum BlacklistType {
  PHONE       // 手机号
  IP          // IP地址
  BANK_CARD   // 银行卡号
}

/**
 * 敏感词表
 * @description 敏感词库管理，用于用户昵称等内容过滤
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.20节 - SensitiveWord表
 * @depends 开发文档/开发文档.md 第13.11.11节 - 敏感词库维护
 * 
 * 核心业务规则：
 * 1. word 唯一索引，防止重复敏感词
 * 2. category 可选，用于分类管理（政治/色情/广告/辱骂等）
 * 3. severity 严重程度 1-3，用于区分处理策略
 * 4. 敏感词过滤开关：GlobalConfig.sensitive_word_filter_enabled
 * 
 * 应用场景：
 * - 用户昵称修改时过滤
 * - 系统公告内容检查（后台管理）
 */
model SensitiveWord {
  id              Int               @id @default(autoincrement())
  
  // === 敏感词信息 ===
  word            String            @unique @db.VarChar(100)        // 敏感词
  category        String?           @db.VarChar(50)                 // 分类（政治/色情/广告/辱骂等）
  severity        Int               @default(1)                     // 严重程度 1-3
  
  // === 状态 ===
  isActive        Boolean           @default(true)                  // 是否启用
  
  // === 操作信息 ===
  createdBy       Int?                                              // 创建人（管理员ID）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引 ===
  @@index([category], map: "idx_sensitive_word_category")
  @@index([isActive], map: "idx_sensitive_word_is_active")
  @@map("sensitive_words")
}

// ================================
// 定时任务相关表
// ================================

/**
 * 定时任务配置表
 * @description 系统定时任务配置，存储任务信息和最后执行状态
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.10节 - ScheduledTask表
 * @depends 开发文档/05-系统核心模块/05.3-定时任务.md - 定时任务清单
 * 
 * 核心业务规则：
 * 1. taskCode 唯一标识任务，禁止重复
 * 2. cronExpression 使用标准 Cron 表达式语法
 * 3. isEnabled 控制任务是否执行
 * 4. lastRunStatus 使用 TaskRunStatus 枚举
 * 
 * 定时任务清单（依据：02.1-数据库设计.md 第2.10节）：
 * | taskCode              | 频率       | 说明                              |
 * |-----------------------|-----------|----------------------------------|
 * | income_settlement     | 每分钟     | 收益发放（最后一笔同步完结订单）      |
 * | recharge_timeout      | 每分钟     | 充值订单超时取消                    |
 * | signin_window_expire  | 每日00:00  | 签到窗口期过期检查                  |
 * | channel_health_check  | 每5分钟    | 支付通道状态检测                    |
 * | daily_stats           | 每日00:05  | 数据统计汇总                       |
 * | stats_archive         | 每日00:30  | 统计数据归档                       |
 */
model ScheduledTask {
  id              Int               @id @default(autoincrement())
  
  // === 任务配置 ===
  taskCode        String            @unique @db.VarChar(50)         // 任务标识（唯一）
  taskName        String            @db.VarChar(100)                // 任务名称
  description     String?           @db.VarChar(500)                // 任务说明
  cronExpression  String            @db.VarChar(50)                 // Cron表达式（禁止硬编码，存数据库）
  
  // === 任务状态 ===
  isEnabled       Boolean           @default(true)                  // 是否启用
  
  // === 最后执行信息 ===
  lastRunAt       DateTime?                                         // 最后执行时间
  lastRunStatus   TaskRunStatus?                                    // 最后执行状态
  lastRunDuration Int?                                              // 最后执行耗时（毫秒）
  nextRunAt       DateTime?                                         // 下次执行时间
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@map("scheduled_tasks")
}

/**
 * 任务执行状态枚举
 * @description 定时任务执行状态，禁止自创
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.10节 - TaskRunStatus枚举
 */
enum TaskRunStatus {
  SUCCESS   // 执行成功
  FAILED    // 执行失败
  RUNNING   // 执行中
}

/**
 * 任务执行日志表
 * @description 记录定时任务每次执行的详细日志
 * @depends 开发文档/02-数据层/02.1-数据库设计.md 第2.10节 - TaskRunLog表
 * 
 * 核心业务规则：
 * 1. 每次任务执行创建一条日志
 * 2. startAt 记录开始时间，endAt 记录结束时间
 * 3. duration = endAt - startAt（毫秒）
 * 4. processedCount 记录处理数量（如发放收益条数）
 * 5. errorMessage 记录失败时的错误信息
 */
model TaskRunLog {
  id              Int               @id @default(autoincrement())
  
  // === 任务标识 ===
  taskCode        String            @db.VarChar(50)                 // 任务标识
  
  // === 执行时间 ===
  startAt         DateTime                                          // 开始时间
  endAt           DateTime?                                         // 结束时间
  duration        Int?                                              // 耗时（毫秒）
  
  // === 执行结果 ===
  status          TaskRunStatus                                     // 执行状态
  processedCount  Int?                                              // 处理数量
  errorMessage    String?           @db.Text                        // 错误信息
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // === 索引（依据：02.1-数据库设计.md 第3.3节）===
  @@index([taskCode], map: "idx_task_run_log_task_code")
  @@index([status], map: "idx_task_run_log_status")
  @@index([startAt], map: "idx_task_run_log_start_at")
  @@map("task_run_logs")
}

// ================================
// 统计相关表
// ================================

/// 每日统计表
model DailyStats {
  id                Int       @id @default(autoincrement())
  date              DateTime  @unique @db.Date /// 统计日期
  newUsers          Int       @default(0) /// 新增用户
  activeUsers       Int       @default(0) /// 活跃用户
  rechargeCount     Int       @default(0) /// 充值笔数
  rechargeAmount    Decimal   @default(0) @db.Decimal(15, 2) /// 充值金额
  withdrawCount     Int       @default(0) /// 提现笔数
  withdrawAmount    Decimal   @default(0) @db.Decimal(15, 2) /// 提现金额
  purchaseCount     Int       @default(0) /// 购买笔数
  purchaseAmount    Decimal   @default(0) @db.Decimal(15, 2) /// 购买金额
  incomeAmount      Decimal   @default(0) @db.Decimal(15, 2) /// 发放收益
  commissionAmount  Decimal   @default(0) @db.Decimal(15, 2) /// 发放返佣
  svipRewardAmount        Decimal @default(0) @db.Decimal(15, 2) /// SVIP奖励发放总额
  weeklySalaryAmount      Decimal @default(0) @db.Decimal(15, 2) /// 周薪发放总额
  prizePoolAmount         Decimal @default(0) @db.Decimal(15, 2) /// 奖池发放总额
  spinWheelAmount         Decimal @default(0) @db.Decimal(15, 2) /// 转盘发放总额
  communityRewardAmount   Decimal @default(0) @db.Decimal(15, 2) /// 社区奖励总额
  financialPrincipalAmount Decimal @default(0) @db.Decimal(15, 2) /// 理财本金返还总额
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("daily_stats")
}

// ================================
// 银行账户-手机号锁定表
// ================================

/**
 * 银行账户-手机号绑定锁定表
 * @description 记录银行账户与用户注册手机号的绑定关系，防止不同手机号用户绑定同一银行账户
 * 
 * 核心规则：
 * 1. 银行账户首次绑定时创建锁定记录（accountNoHash 唯一索引）
 * 2. 锁定记录永久保留，不随银行卡软删除而消失
 * 3. 管理员可通过 isLocked 字段手动解锁/重锁
 * 4. 解锁后新用户绑定时，更新 phone/userId 并重新锁定
 */
model AccountPhoneBind {
  id              Int       @id @default(autoincrement())
  accountNoHash   String    @unique @db.VarChar(64)        // SHA256哈希（快速查找，唯一索引）
  accountNo       String    @db.VarChar(255)               // AES加密存储（后台可解密显示）
  accountNoMask   String    @db.VarChar(50)                // 脱敏显示 ****1234
  phone           String    @db.VarChar(20)                // 首次绑定的用户注册手机号
  userId          Int                                       // 首次绑定的用户ID
  isLocked        Boolean   @default(true)                 // 管理员可解锁
  unlockedBy      Int?                                      // 解锁的管理员ID
  unlockedAt      DateTime?                                 // 解锁时间
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([phone], map: "idx_account_phone_bind_phone")
  @@map("account_phone_binds")
}

// ================================
// 渠道链接相关表
// ================================

/**
 * 渠道链接表
 * @description 管理员创建的推广渠道，绑定某个用户的邀请码用于追踪推广效果
 * 每个渠道绑定唯一用户，避免统计数据重叠
 */
model MarketingChannel {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)               // 渠道名称（如"Facebook推广"）
  userId      Int       @unique                        // 关联用户ID（unique：一个用户只能绑定一个渠道）
  remark      String?   @db.VarChar(500)               // 备注说明
  isActive    Boolean   @default(true)                 // 是否启用

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // === 关联关系 ===
  user        User      @relation(fields: [userId], references: [id])

  // === 索引 ===
  @@index([isActive], map: "idx_marketing_channel_active")
  @@map("marketing_channels")
}

