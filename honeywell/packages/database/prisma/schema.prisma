/// 社区帖子
model CommunityPost {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  withdrawOrderId Int?      @map("withdraw_order_id")
  withdrawAmount  Decimal?  @db.Decimal(15, 2) @map("withdraw_amount")
  platformImage   String?   @map("platform_image") @db.VarChar(500)
  receiptImage    String?   @map("receipt_image") @db.VarChar(500)
  content         String?   @db.Text
  status          String    @default("PENDING") @db.VarChar(20)
  reviewedBy      Int?      @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  rewardAmount    Decimal?  @db.Decimal(15, 2) @map("reward_amount")
  rewardedAt      DateTime? @map("rewarded_at")
  likeCount       Int       @default(0) @map("like_count")
  commentCount    Int       @default(0) @map("comment_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id])
  comments        CommunityComment[]
  likes           CommunityLike[]

  @@index([userId], map: "idx_community_post_user_id")
  @@index([status], map: "idx_community_post_status")
  @@map("community_posts")
}

/// 社区评论
model CommunityComment {
  id              Int       @id @default(autoincrement())
  postId          Int       @map("post_id")
  userId          Int       @map("user_id")
  content         String    @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id])

  @@index([postId], map: "idx_community_comment_post_id")
  @@index([userId], map: "idx_community_comment_user_id")
  @@map("community_comments")
}

/// 社区点赞
model CommunityLike {
  id              Int       @id @default(autoincrement())
  postId          Int       @map("post_id")
  userId          Int       @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id])

  @@unique([postId, userId], map: "unique_community_like_post_user")
  @@index([userId], map: "idx_community_like_user_id")
  @@map("community_likes")
}

/// 社区奖励档位
model CommunityRewardTier {
  id              Int       @id @default(autoincrement())
  minAmount       Decimal   @db.Decimal(15, 2) @map("min_amount")
  maxAmount       Decimal   @db.Decimal(15, 2) @map("max_amount")
  rewardAmount    Decimal   @db.Decimal(15, 2) @map("reward_amount")
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("community_reward_tiers")
}

// ================================
// 礼品码系统
// ================================

/// 礼品码金额类型
enum GiftCodeAmountType {
  FIXED     // 固定金额：每人领取相同金额
  RANDOM    // 拼手气：从总金额池中随机分配
}

/// 礼品码状态
enum GiftCodeStatus {
  ACTIVE     // 进行中
  DISABLED   // 已禁用
  EXPIRED    // 已过期
  EXHAUSTED  // 已领完
}

/// 礼品码前置条件
enum GiftCodeRequirement {
  NONE            // 无前置条件
  MUST_PURCHASE   // 必须购买过付费产品
}

/// 礼品码主表
model GiftCode {
  id             Int                  @id @default(autoincrement())
  code           String               @unique @db.VarChar(32)
  name           String               @db.VarChar(100)
  amountType     GiftCodeAmountType   @map("amount_type")
  requirement    GiftCodeRequirement  @default(NONE)

  // === 金额配置 ===
  fixedAmount    Decimal?             @db.Decimal(15, 2) @map("fixed_amount")
  totalAmount    Decimal              @db.Decimal(15, 2) @map("total_amount")
  remainAmount   Decimal              @db.Decimal(15, 2) @map("remain_amount")
  minAmount      Decimal?             @db.Decimal(15, 2) @map("min_amount")
  maxAmount      Decimal?             @db.Decimal(15, 2) @map("max_amount")

  // === 份数控制 ===
  totalCount     Int                  @map("total_count")
  claimedCount   Int                  @default(0) @map("claimed_count")

  // === 状态与有效期 ===
  status         GiftCodeStatus       @default(ACTIVE)
  startAt        DateTime?            @map("start_at")
  expireAt       DateTime?            @map("expire_at")

  // === 管理信息 ===
  createdBy      Int                  @map("created_by")
  admin          Admin                @relation(fields: [createdBy], references: [id])
  remark         String?              @db.VarChar(500)

  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  claims         GiftCodeClaim[]

  @@index([code], map: "idx_gift_code_code")
  @@index([status], map: "idx_gift_code_status")
  @@index([expireAt], map: "idx_gift_code_expire_at")
  @@map("gift_codes")
}

/// 礼品码领取记录
model GiftCodeClaim {
  id             Int       @id @default(autoincrement())
  giftCodeId     Int       @map("gift_code_id")
  giftCode       GiftCode  @relation(fields: [giftCodeId], references: [id])
  userId         Int       @map("user_id")
  user           User      @relation(fields: [userId], references: [id])
  amount         Decimal   @db.Decimal(15, 2)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([giftCodeId, userId], map: "uk_gift_code_claim_user")
  @@index([userId], map: "idx_gift_code_claim_user_id")
  @@index([giftCodeId], map: "idx_gift_code_claim_code_id")
  @@map("gift_code_claims")
}
