# Docker Compose 环境变量
MYSQL_ROOT_PASSWORD=root123
MYSQL_USER=honeywell
MYSQL_PASSWORD=honeywell123

# 数据库连接（用于本地开发）
DATABASE_URL=mysql://honeywell:honeywell123@localhost:3306/honeywell

# Redis 连接
REDIS_URL=redis://localhost:6379

# 加密密钥（生产环境请更换为随机32位字符串）
AES_SECRET_KEY=your-32-character-aes-secret-key

# JWT 密钥
JWT_SECRET=your-jwt-secret-key-at-least-16
ADMIN_JWT_SECRET=your-admin-jwt-secret-key-min16

# 站点配置
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# NextAuth 配置
NEXTAUTH_SECRET=your-nextauth-secret-key-32chars-
NEXTAUTH_URL=http://localhost:3000

# 支付回调域名（生产环境配置实际域名）
CALLBACK_DOMAIN=http://localhost:3002

# 文件上传
UPLOAD_DIR=/uploads
MAX_FILE_SIZE=10485760
